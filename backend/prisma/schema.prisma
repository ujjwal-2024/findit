generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String?  @map("password_hash")
  avatarUrl    String?  @map("avatar_url")
  googleId     String?  @unique @map("google_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  items         Item[]
  notifications Notification[]

  @@map("users")
}

model Item {
  id            String     @id @default(uuid())
  userId        String     @map("user_id")
  type          ItemType
  title         String
  description   String
  category      Category
  location      String
  imageUrl      String     @map("image_url")
  imagePublicId String     @map("image_public_id")
  status        ItemStatus @default(ACTIVE)
  dateOccurred  DateTime   @map("date_occurred")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  lostMatches    Match[] @relation("LostItem")
  foundMatches   Match[] @relation("FoundItem")

  @@map("items")
}

model Match {
  id           String   @id @default(uuid())
  lostItemId   String   @map("lost_item_id")
  foundItemId  String   @map("found_item_id")
  score        Float
  aiReasoning  String   @map("ai_reasoning")
  notified     Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")

  lostItem      Item           @relation("LostItem", fields: [lostItemId], references: [id], onDelete: Cascade)
  foundItem     Item           @relation("FoundItem", fields: [foundItemId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@unique([lostItemId, foundItemId])
  @@map("matches")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  matchId   String   @map("match_id")
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum ItemType {
  LOST
  FOUND
}

enum Category {
  ELECTRONICS
  CLOTHING
  DOCUMENTS
  PETS
  JEWELLERY
  BAGS
  KEYS
  OTHER
}

enum ItemStatus {
  ACTIVE
  MATCHED
  RETURNED
  CLOSED
}
